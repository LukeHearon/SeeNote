{
  "productName": "SeeNote",
  "version": "0.12.0",
  "identifier": "com.seenote.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SeeNote",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "plugins": {
    "dialog": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "mp3"
        ],
        "name": "MP3 Audio",
        "description": "Audio file",
        "mimeType": "audio/mpeg",
        "role": "Viewer"
      },
      {
        "ext": [
          "flac"
        ],
        "name": "FLAC Audio",
        "description": "Audio file",
        "mimeType": "audio/flac",
        "role": "Viewer"
      },
      {
        "ext": [
          "wav"
        ],
        "name": "WAV Audio",
        "description": "Audio file",
        "mimeType": "audio/wav",
        "role": "Viewer"
      },
      {
        "ext": [
          "aac"
        ],
        "name": "AAC Audio",
        "description": "Audio file",
        "mimeType": "audio/aac",
        "role": "Viewer"
      },
      {
        "ext": [
          "m4a"
        ],
        "name": "M4A Audio",
        "description": "Audio file",
        "mimeType": "audio/x-m4a",
        "role": "Viewer"
      },
      {
        "ext": [
          "mp4"
        ],
        "name": "MP4 Video",
        "description": "Video file",
        "mimeType": "video/mp4",
        "role": "Viewer"
      },
      {
        "ext": [
          "m4v"
        ],
        "name": "M4V Video",
        "description": "Video file",
        "mimeType": "video/x-m4v",
        "role": "Viewer"
      },
      {
        "ext": [
          "mov"
        ],
        "name": "QuickTime Video",
        "description": "Video file",
        "mimeType": "video/quicktime",
        "role": "Viewer"
      },
      {
        "ext": [
          "mkv"
        ],
        "name": "Matroska Video",
        "description": "Video file",
        "mimeType": "video/x-matroska",
        "role": "Viewer"
      },
      {
        "ext": [
          "webm"
        ],
        "name": "WebM Video",
        "description": "Video file",
        "mimeType": "video/webm",
        "role": "Viewer"
      }
    ]
  }
}
